{
    "manifest_version": 3,
    "name": "Kawach",
    "version": "1.0",
    "description": "A dual-threat AI Chrome Extension acting as an active digital shield.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:8080/*"
    ],
    "action": {
        "default_popup": "popup/index.html"
    }
}